{
  "id": "binary_palindrome",
  "name": "Palíndromo binario",
  "description": "Acepta palíndromos sobre el alfabeto $\\{0,1\\}$",
  "states": ["q0", "q1", "q2", "q3a", "q3b", "q4", "q_accept", "q_reject"],
  "input_alphabet": ["0", "1"],
  "tape_alphabet": ["0", "1", "X", "_"],
  "blank": "_",
  "initial_state": "q0",
  "accept_states": ["q_accept"],
  "reject_states": ["q_reject"],
  "transitions": [
    {"from": "q0", "read": "0", "to": "q1", "write": "X", "move": "R"},
    {"from": "q0", "read": "1", "to": "q2", "write": "X", "move": "R"},
    {"from": "q0", "read": "X", "to": "q0", "write": "X", "move": "R"},
    {"from": "q0", "read": "_", "to": "q_accept", "write": "_", "move": "R"},
    {"from": "q1", "read": "0", "to": "q1", "write": "0", "move": "R"},
    {"from": "q1", "read": "1", "to": "q1", "write": "1", "move": "R"},
    {"from": "q1", "read": "X", "to": "q1", "write": "X", "move": "R"},
    {"from": "q1", "read": "_", "to": "q3a", "write": "_", "move": "L"},
    {"from": "q2", "read": "0", "to": "q2", "write": "0", "move": "R"},
    {"from": "q2", "read": "1", "to": "q2", "write": "1", "move": "R"},
    {"from": "q2", "read": "X", "to": "q2", "write": "X", "move": "R"},
    {"from": "q2", "read": "_", "to": "q3b", "write": "_", "move": "L"},
    {"from": "q3a", "read": "0", "to": "q4", "write": "X", "move": "L"},
    {"from": "q3a", "read": "1", "to": "q_reject", "write": "1", "move": "R"},
    {"from": "q3a", "read": "X", "to": "q0", "write": "X", "move": "R"},
    {"from": "q3a", "read": "_", "to": "q_reject", "write": "_", "move": "R"},
    {"from": "q3b", "read": "1", "to": "q4", "write": "X", "move": "L"},
    {"from": "q3b", "read": "0", "to": "q_reject", "write": "0", "move": "R"},
    {"from": "q3b", "read": "X", "to": "q0", "write": "X", "move": "R"},
    {"from": "q3b", "read": "_", "to": "q_reject", "write": "_", "move": "R"},
    {"from": "q4", "read": "0", "to": "q4", "write": "0", "move": "L"},
    {"from": "q4", "read": "1", "to": "q4", "write": "1", "move": "L"},
    {"from": "q4", "read": "X", "to": "q0", "write": "X", "move": "R"},
    {"from": "q4", "read": "_", "to": "q_reject", "write": "_", "move": "R"}
  ]
}

{
  "id": "unary_increment",
  "name": "Incremento unario",
  "description": "Entrada $1^n$ produce $1^{n+1}$ en la cinta",
  "examples": [
    {"input": "1", "label": "Un solo 1 → acepta (incrementa a 11)"},
    {"input": "111", "label": "Tres unos → acepta"},
    {"input": "11111", "label": "Cinco unos → acepta"},
    {"input": "", "label": "ε → rechaza (se necesita al menos un 1)"},
    {"input": "11", "label": "Dos unos → acepta; observe la cinta al finalizar"}
  ],
  "states": ["q0", "q1", "q_accept", "q_reject"],
  "input_alphabet": ["1"],
  "tape_alphabet": ["1", "_"],
  "blank": "_",
  "initial_state": "q0",
  "accept_states": ["q_accept"],
  "reject_states": ["q_reject"],
  "transitions": [
    {"from": "q0", "read": "1", "to": "q0", "write": "1", "move": "R"},
    {"from": "q0", "read": "_", "to": "q1", "write": "1", "move": "L"},
    {"from": "q1", "read": "1", "to": "q_accept", "write": "1", "move": "R"},
    {"from": "q1", "read": "_", "to": "q_reject", "write": "_", "move": "R"}
  ]
}
